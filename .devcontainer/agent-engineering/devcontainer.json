{
  "name": "Git-Ape Agent Engineering",
  "image": "mcr.microsoft.com/devcontainers/python:3-3.12-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/powershell:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/copilot-cli:1": {}
  },

  "onCreateCommand": "bash .devcontainer/agent-engineering/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-azuretools.vscode-azurefunctions",
        "ms-azuretools.vscode-azure-mcp-server",
        "bewhite.psrule-vscode",
        "ms-vscode.vscode-chat-customizations-evaluations"
      ],
      "settings": {
        "azureMcp.serverMode": "namespace",
        "azureMcp.readOnly": false,
        "task.allowAutomaticTasks": "on",
        "chatCustomizationsEvaluations.waza.command": "waza"
      }
    }
  },

  "remoteUser": "vscode"
}
